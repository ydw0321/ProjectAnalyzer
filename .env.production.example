# Core
PROJECT_PATH=/srv/project/java-src
CHROMA_DB_PATH=/var/lib/project-analyzer/chroma
LOG_LEVEL=INFO

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=replace_with_real_password

# LLM
LLM_API_URL=https://your-llm-endpoint.example.com/v1/chat/completions
LLM_API_KEY=replace_with_real_api_key
LLM_MODEL=your-model-name
LLM_TIMEOUT=60
USE_SIGNATURE_MATCH=true

# Graph query guards
QUERY_TIMEOUT=30
MAX_CALL_DEPTH=10
HARD_MAX_CALL_DEPTH=20
MAX_QUERY_RESULTS=1000
MAX_METHOD_FANOUT=100
MAX_NODE_COUNT=1000
MAX_TREE_DEPTH=10
MAX_SUB_PACKAGE_DEPTH=3