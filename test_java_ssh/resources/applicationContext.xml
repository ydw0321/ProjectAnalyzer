    <bean id="paymentService" class="com.legacy.ssh.service.impl.payment.LegacyPaymentServiceImpl"/>

    <bean id="orderDAO" class="com.legacy.ssh.dao.order.OrderDAO"/>
    <bean id="orderDetailDAO" class="com.legacy.ssh.dao.order.OrderDetailDAO"/>

    <bean id="retryInterceptor" class="com.legacy.ssh.interceptor.RetryInterceptor"/>
