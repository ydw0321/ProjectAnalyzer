<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="
       http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans-2.5.xsd">

    <bean id="orderService" class="com.legacy.ssh.service.impl.order.OrderServiceImpl"/>
    <bean id="orderServiceProxy" class="com.legacy.ssh.service.impl.order.OrderServiceProxy"/>
    <bean id="legacyMegaWorkflowService" class="com.legacy.ssh.service.impl.order.LegacyMegaWorkflowService"/>
    <bean id="deepChainCoordinator" class="com.legacy.ssh.service.impl.order.DeepChainCoordinator"/>
