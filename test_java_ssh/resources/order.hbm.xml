<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-mapping PUBLIC
        "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-mapping-3.0.dtd">
<hibernate-mapping>
    <class name="com.legacy.ssh.model.order.Order" table="t_order">
        <id name="orderId" column="order_id" type="string"/>
        <property name="userId" column="user_id" type="string"/>
        <property name="status" column="status" type="string"/>
        <property name="createdAt" column="created_at" type="long"/>
        <property name="updatedAt" column="updated_at" type="long"/>
    </class>
</hibernate-mapping>
